{
	"schemaVersion": 1,
	"id": "allbut1",
	"version": "${version}",
	"name": "AllBut1",
	"description": "This mod lets you take a stack out of a container, but leave 1.",
	"authors": [ "Haage" ],
	"contact": {
		"homepage": "https://modrinth.com/mod/all-but-1",
		"issues": "https://github.com/Haage001/All-But-1/issues"
	},
	"license": "MIT",
	"icon": "assets/allbut1/icon.png",
	"environment": "*",

	"entrypoints": {
		"main": [
			"haage.allbut1.AllBut1"
		],
		"client": [
			"haage.allbut1.AllBut1Client"
		],
		"fabric-datagen": [
			"haage.allbut1.AllBut1DataGenerator"
		]
	},

	"mixins": [
		"allbut1.mixins.json"
	],

	"depends": {
		"fabricloader": ">=0.19.3",
		"fabric-api": "*",
		"minecraft": ">=26.2-rc.2",
		"java": ">=25"
	}
}
